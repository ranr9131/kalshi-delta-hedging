KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your-private-key-here
-----END RSA PRIVATE KEY-----"
PAPER_MODE=true
BASE_STAKE=100.0
# t+5 | dh-target (recommended) | dh-additive
MODE=dh-target
MIN_BET=5.0
# Skip bets where fill price exceeds this (avoids illiquid contracts near 0/1)
MAX_FILL=0.97
# Betting frequency inside the DH loop: 1=every 60s, 2=every 30s, 4=every 15s
BETS_PER_MIN=4
# Comma-separated UTC hours to trade, e.g. "13,14,18,22". Empty = all 24h.
ACTIVE_HOURS=
# Soft velocity multiplier steepness. BTC trending with your bet → larger bet; against → smaller.
# f_vel = 2.0/(1+exp(-k*vel_pct)), neutral at vel=0 (f_vel=1.0). Recommended: 100. Leave empty to disable.
VEL_SOFT_K=100
